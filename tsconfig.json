{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"declaration": false,
		"outDir": ".",
		"baseUrl": ".",
		"lib": ["ES2022", "DOM"],
		"typeRoots": ["./node_modules/@types"],
		"ignoreDeprecations": "6.0"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}