  },
  "keywords": ["obsidian", "plugin", "logseq", "todo"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "obsidian": "^1.12.3",
    "typescript": "^6.0.2"
  }
}